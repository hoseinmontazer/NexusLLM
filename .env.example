# NexusLLM environment variables
# Copy to .env and fill in real values before running locally.
# Prefix all variables with NEXUS_ when loading via viper.

# ── Server ────────────────────────────────────────────────────────────────────
NEXUS_SERVER_PORT=8080
NEXUS_SERVER_METRICSPORT=9090
NEXUS_SERVER_MODE=debug          # debug | release

# ── Admin server (separate binary) ───────────────────────────────────────────
NEXUS_ADMIN_PORT=8081

# ── PostgreSQL ────────────────────────────────────────────────────────────────
NEXUS_DATABASE_DSN=postgres://nexus:nexus@localhost:5432/nexusllm?sslmode=disable
NEXUS_DATABASE_MAXOPENCONNS=20
NEXUS_DATABASE_MAXIDLECONNS=5
NEXUS_DATABASE_CONNMAXLIFETIME=5m

# ── Redis ─────────────────────────────────────────────────────────────────────
NEXUS_REDIS_ADDR=localhost:6379
NEXUS_REDIS_PASSWORD=
NEXUS_REDIS_DB=0

# ── Auth ──────────────────────────────────────────────────────────────────────
NEXUS_AUTH_JWTSECRET=change-me-in-production
NEXUS_AUTH_APIKEYCACHETTL=5m
NEXUS_AUTH_JWTCACHETTL=1m

# ── Scheduler ─────────────────────────────────────────────────────────────────
NEXUS_SCHEDULER_QUEUEHIGHSTREAM=nexus:queue:high
NEXUS_SCHEDULER_QUEUEMEDSTREAM=nexus:queue:med
NEXUS_SCHEDULER_QUEUELOWSTREAM=nexus:queue:low
NEXUS_SCHEDULER_DISPATCHINTERVAL=100ms

# ── vLLM Endpoints ────────────────────────────────────────────────────────────
# In production these point to Kubernetes Service DNS names.
# For local testing without GPUs, point to a mock or leave default.
NEXUS_VLLM_POLLINTERVAL=5s
# Individual model endpoints can also be passed as a YAML config file.

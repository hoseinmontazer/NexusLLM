FROM golang:1.22-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-w -s" -o /nexus-nodeagent ./cmd/nodeagent

FROM alpine:3.19
# Install runtime tools the agent reads from
RUN apk add --no-cache \
    util-linux \
    numactl \
    coreutils \
    procps

COPY --from=builder /nexus-nodeagent /nexus-nodeagent

# State directory for persisting node ID across restarts
RUN mkdir -p /var/lib/nexus-agent

ENTRYPOINT ["/nexus-nodeagent"]
